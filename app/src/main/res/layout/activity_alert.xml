<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/background">

    <TextView android:text="設定匯率提醒" android:textSize="24sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <Spinner android:id="@+id/spinnerAlertFrom" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:background="@drawable/spinner_bg"/>
    <Spinner android:id="@+id/spinnerAlertTo" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/spinner_bg"/>

    <EditText
        android:id="@+id/etTargetRate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:hint="目標匯率 (例如 31.5)"
        android:inputType="numberDecimal"
        android:background="@drawable/edittext_bg"
        android:padding="16dp"/>

    <Switch
        android:id="@+id/switchAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="啟用提醒監控"/>

    <TextView
        android:id="@+id/tvCurrentAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textSize="16sp"
        android:textColor="@color/primary"/>

    <Button
        android:id="@+id/btnStartAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="啟動提醒監控"
        android:backgroundTint="@color/primary"/>

    <Button
        android:id="@+id/btnStopAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="停用提醒"
        android:backgroundTint="@color/error"/>
</LinearLayout>